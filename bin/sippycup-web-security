#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
readonly project_dir

usage() {
    cat <<'EOF'
Usage: sippycup web-security COMMAND

Compile and inspect bounded admin/WebSocket security evidence.

Commands:
  plan PROFILE.json ADAPTER.json [--now UTC]
      Compile fixed service-specific cases without network activity.
  evidence PLAN.json OBSERVATION.json
      Evaluate normalized results without network activity.
  help
      Show this help.

This command does not execute probes. A plan never grants authorization and
does not expose an arbitrary HTTP request, WebSocket message, URL, or payload.
Network activity: none
EOF
}

command_name="${1:-help}"
if (( $# > 0 )); then
    shift
fi

case "${command_name}" in
    help|--help|-h)
        if (( $# != 0 )); then
            printf 'help accepts no arguments.\n' >&2
            exit 2
        fi
        usage
        ;;
    plan)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/web-security-profile" "$@"
        ;;
    evidence)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/web-security-evidence" "$@"
        ;;
    *)
        printf 'Unknown web-security command: %s\n' "${command_name}" >&2
        usage >&2
        exit 2
        ;;
esac

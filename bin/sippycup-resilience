#!/usr/bin/env python3
"""Bounded voice-edge resilience oracles."""

from __future__ import annotations

from pathlib import Path
import sys

source_lib = Path(__file__).resolve().parents[1] / "lib"
if not (source_lib / "sippycup_resilience").is_dir():
    source_lib = Path("/usr/local/lib")
sys.path.insert(0, str(source_lib))

from sippycup_resilience.cli import main

if __name__ == "__main__":
    raise SystemExit(main())

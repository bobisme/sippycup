#!/usr/bin/env bash
set -euo pipefail

commands=(
    age
    age-keygen
    baresip
    boo
    campaign
    campaign-sipp-runner
    campaign-loopback-uas
    campaign-integration-selftest
    capinfos
    dumpcap
    editcap
    ffmpeg
    gst-launch-1.0
    hping3
    iperf3
    minisign
    mergecap
    nc
    ngrep
    nmap
    nsenter
    openssl
    pasta
    pjsua
    scapy
    setpriv
    sipp
    sipsak
    sipvicious_svcrack
    sipvicious_svmap
    sipvicious_svreport
    sipvicious_svwar
    sippycup-preflight
    sippycup-assert
    sippycup-chaos
    sippycup-diff
    sippycup-evidence
    sippycup-pack
    sippycup-envelope
    sippycup-media
    sippycup-media-echo
    sippycup-torture
    sippycup-ui
    sippycup-resilience
    sippycup-workbench
    sippycup-report
    sippycup-selftest
    sngrep
    socat
    sox
    sslscan
    tc
    tcpdump
    tcpreplay
    termshark
    testssl
    text2pcap
    tshark
    turnutils_peer
    turnutils_stunclient
    turnutils_uclient
    reordercap
)

missing=0
for tool in "${commands[@]}"; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
        printf 'MISSING  %s\n' "${tool}" >&2
        missing=1
    else
        printf 'ok       %s\n' "${tool}"
    fi
done

PYTHONPATH=/usr/local/lib python3 - <<'PY'
import boofuzz
import scapy.all
import sipvicious
import yaml
import sippycup
import sippycup_chaos
import sippycup_learn
import sippycup_media
import sippycup_resilience
import sippycup_oracle
import sippycup_torture
import sippycup_tui
import sippycup_workbench
print("ok       Python modules: dependencies and all first-party packages")
PY

if (( missing != 0 )); then
    exit 1
fi

first_party_help=(
    campaign
    sippycup-assert
    sippycup-chaos
    sippycup-diff
    sippycup-envelope
    sippycup-evidence
    sippycup-media
    sippycup-media-echo
    sippycup-pack
    sippycup-torture
    sippycup-ui
    sippycup-resilience
    sippycup-workbench
)
for tool in "${first_party_help[@]}"; do
    "${tool}" --help >/dev/null
    printf 'ok       %s --help\n' "${tool}"
done

journal_parent="$(mktemp -d)"
sippycup-workbench journal init "${journal_parent}/assessment" >/dev/null
sippycup-workbench journal add "${journal_parent}/assessment" \
    --kind note --summary "container smoke journal entry" >/dev/null
sippycup-workbench journal verify "${journal_parent}/assessment" >/dev/null
printf 'ok       workbench journal lifecycle\n'

sippycup-torture exit-gate >/dev/null
printf 'ok       torture technical exit gate\n'

set +e
status_json="$(
    sippycup-workbench status "${journal_parent}/assessment" --format json
)"
status_code=$?
set -e
test "${status_code}" -eq 1
printf '%s' "${status_json}" \
    | jq -e '.networkActivity == false and .overall == "blocked"' >/dev/null
printf 'ok       offline engagement advisor\n'

printf '\nSIPp build:\n'
set +e
sipp_version="$(sipp -v 2>&1)"
sipp_status=$?
set -e

if [[ "${sipp_status}" -ne 0 && "${sipp_status}" -ne 99 ]]; then
    printf '%s\n' "${sipp_version}" >&2
    exit "${sipp_status}"
fi

printf '%s\n' "${sipp_version}" | sed -n '1,8p'

printf '\nPJSUA build:\n'
pjsua_version="$(pjsua --version 2>&1)"
printf '%s\n' "${pjsua_version}" | sed -n '1,12p'
if ! printf '%s\n' "${pjsua_version}" | grep -q 'PJ_VERSION[[:space:]]*: 2.17'; then
    printf 'PJSUA did not report the pinned 2.17 version.\n' >&2
    exit 1
fi
if ! printf '%s\n' "${pjsua_version}" | grep -q 'PJ_HAS_IPV6[[:space:]]*: 1'; then
    printf 'PJSUA was built without required IPv6 support.\n' >&2
    exit 1
fi
if ! printf '%s\n' "${pjsua_version}" | grep -q 'PJ_HAS_SSL_SOCK[[:space:]]*: 1'; then
    printf 'PJSUA was built without required TLS support.\n' >&2
    exit 1
fi

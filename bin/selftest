#!/usr/bin/env bash
set -euo pipefail

output="${1:-/work/selftest.pcap}"
cap_pid=""
uas_pid=""

cleanup() {
    if [[ -n "${cap_pid}" ]]; then
        kill -INT "${cap_pid}" 2>/dev/null || true
        wait "${cap_pid}" 2>/dev/null || true
    fi
    if [[ -n "${uas_pid}" ]]; then
        kill "${uas_pid}" 2>/dev/null || true
        wait "${uas_pid}" 2>/dev/null || true
    fi
}
trap cleanup EXIT

tcpdump -U -ni lo -w "${output}" \
    "udp port 5098 or udp port 5099" >/tmp/sippycup-tcpdump.log 2>&1 &
cap_pid=$!

sipp -sn uas \
    -i 127.0.0.1 \
    -p 5099 \
    -m 1 \
    -timeout 10s \
    -trace_err >/tmp/sippycup-uas.log 2>&1 &
uas_pid=$!

sleep 1

sipp 127.0.0.1:5099 \
    -sn uac \
    -i 127.0.0.1 \
    -p 5098 \
    -m 1 \
    -r 1 \
    -timeout 8s \
    -trace_err >/tmp/sippycup-uac.log 2>&1

wait "${uas_pid}"
uas_pid=""
sleep 1

kill -INT "${cap_pid}" 2>/dev/null || true
wait "${cap_pid}" 2>/dev/null || true
cap_pid=""

test -s "${output}"

printf 'Closed-loop SIP call succeeded. Captured SIP messages:\n'
tshark -r "${output}" -Y sip -T fields \
    -e frame.number \
    -e sip.Method \
    -e sip.Status-Code
printf '\nCapture: %s\n' "${output}"

#!/usr/bin/env python3
"""Portable evidence pack CLI."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))

from sippycup.evidence_pack import (
    EvidencePackError,
    create_evidence_pack,
    export_ci,
    render_verification_json,
    render_verification_junit,
    render_verification_markdown,
    sign_evidence_pack,
    verify_evidence_pack,
)


def main(argv=None) -> int:
    parser = argparse.ArgumentParser(prog="sippycup-pack")
    commands = parser.add_subparsers(dest="command", required=True)
    create = commands.add_parser("create")
    create.add_argument("run_dir", type=Path)
    create.add_argument("output", type=Path)
    create.add_argument("--image-digest", required=True)
    create.add_argument("--recipient", action="append", default=[])
    sign = commands.add_parser("sign")
    sign.add_argument("pack", type=Path)
    sign.add_argument("--secret-key", required=True, type=Path)
    sign.add_argument("--output", type=Path)
    verify = commands.add_parser("verify")
    verify.add_argument("pack", type=Path)
    verify.add_argument("--signature", type=Path)
    verify.add_argument("--public-key", type=Path)
    verify.add_argument("--format", choices=("json", "markdown", "junit"), default="json")
    export = commands.add_parser("export-ci")
    export.add_argument("pack", type=Path)
    export.add_argument("output", type=Path)
    export.add_argument("--include-artifact", action="append", default=[])
    export.add_argument("--allow-privacy-findings", action="store_true")
    arguments = parser.parse_args(argv)
    try:
        if arguments.command == "create":
            result = create_evidence_pack(
                arguments.run_dir,
                arguments.output,
                image_digest=arguments.image_digest,
                recipients=arguments.recipient,
            )
            print(json.dumps(result, indent=2, sort_keys=True))
            return 0
        if arguments.command == "sign":
            result = sign_evidence_pack(
                arguments.pack, arguments.secret_key, arguments.output
            )
            print(result)
            return 0
        if arguments.command == "export-ci":
            result = export_ci(
                arguments.pack,
                arguments.output,
                include_artifacts=arguments.include_artifact,
                allow_privacy_findings=arguments.allow_privacy_findings,
            )
            print(json.dumps(result, indent=2, sort_keys=True))
            return 0
        result = verify_evidence_pack(
            arguments.pack,
            signature=arguments.signature,
            public_key=arguments.public_key,
        )
        renderer = {
            "json": render_verification_json,
            "markdown": render_verification_markdown,
            "junit": render_verification_junit,
        }[arguments.format]
        sys.stdout.write(renderer(result))
        return {
            "pass": 0,
            "content-failure": 1,
            "signature-failure": 3,
        }[result["verdict"]]
    except (EvidencePackError, OSError) as error:
        print(f"sippycup-pack: error: {error}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())

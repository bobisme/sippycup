#!/usr/bin/env python3
"""Tiny unauthenticated loopback SIP UAS for the campaign integration self-test."""

import socket
import sys


port = int(sys.argv[1]) if len(sys.argv) > 1 else 5099
server = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
server.bind(("127.0.0.1", port))


def headers(message):
    result = {}
    for line in message.split("\r\n")[1:]:
        if not line:
            break
        if ":" in line:
            name, value = line.split(":", 1)
            result[name.lower()] = value.strip()
    return result


def response(status, request_headers, body=""):
    to = request_headers.get("to", "")
    if ";tag=" not in to:
        to += ";tag=sippycup-uas"
    lines = [
        f"SIP/2.0 {status}",
        f"Via: {request_headers.get('via', '')}",
        f"From: {request_headers.get('from', '')}",
        f"To: {to}",
        f"Call-ID: {request_headers.get('call-id', '')}",
        f"CSeq: {request_headers.get('cseq', '')}",
        f"Contact: <sip:sippycup@127.0.0.1:{port}>",
    ]
    if body:
        lines.append("Content-Type: application/sdp")
    lines.append(f"Content-Length: {len(body.encode())}")
    return ("\r\n".join(lines) + "\r\n\r\n" + body).encode()


while True:
    packet, peer = server.recvfrom(65535)
    message = packet.decode(errors="replace")
    first = message.split("\r\n", 1)[0]
    parsed = headers(message)
    if first.startswith("OPTIONS "):
        server.sendto(response("200 OK", parsed), peer)
    elif first.startswith("INVITE "):
        server.sendto(response("100 Trying", parsed), peer)
        server.sendto(response("180 Ringing", parsed), peer)
        sdp = (
            "v=0\r\n"
            "o=sippycup 1 1 IN IP4 127.0.0.1\r\n"
            "s=sippycup\r\n"
            "c=IN IP4 127.0.0.1\r\n"
            "t=0 0\r\n"
            "m=audio 10000 RTP/AVP 0\r\n"
            "a=rtpmap:0 PCMU/8000\r\n"
        )
        server.sendto(response("200 OK", parsed, sdp), peer)
    elif first.startswith("BYE "):
        server.sendto(response("200 OK", parsed), peer)
        break

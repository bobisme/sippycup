#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
readonly project_dir
readonly core_image="${SIPPYCUP_IMAGE:-localhost/sippycup:latest}"
readonly image="${SIPPYCUP_WEBRTC_IMAGE:-localhost/sippycup-webrtc:latest}"

usage() {
    cat <<'EOF'
Usage: sippycup-webrtc COMMAND

Manage the optional independent WebRTC peer profile.

Commands:
  build          Build the pinned optional profile
  status         Report whether the optional image is installed
  capabilities   Print the peer's network-free capability contract
  validate       Validate a scenario/result offline
  self-test      Run one bounded Pion-to-Pion audio call on loopback
  signaling-self-test
                 Run bounded browser-style WSS checks on loopback
  relay-self-test Run a bounded audio call through loopback TURN only
  exit-gate      Run the disposable local interoperability/safety gate
  ice-turn       Evaluate normalized ICE/STUN/TURN evidence offline
  sdp            Evaluate, generate, or minimize normalized SDP evidence
  media-security Evaluate normalized DTLS-SRTP evidence offline
  call-evidence   Correlate normalized WebRTC call evidence offline
  help           Show this help

No command can contact an assessment target. The self-test uses only loopback,
drops all capabilities, has a read-only root filesystem, and runs with no
external container network.
EOF
}

runtime_path() {
    "${project_dir}/bin/container-runtime"
}

image_exists() {
    local runtime="$1"
    "${runtime}" image inspect "${image}" >/dev/null 2>&1
}

require_image() {
    local runtime="$1"
    if ! image_exists "${runtime}"; then
        printf 'Optional WebRTC image is not installed: %s\n' "${image}" >&2
        printf 'Run: ./bin/sippycup webrtc build\n' >&2
        exit 1
    fi
}

run_confined() {
    local runtime="$1"
    shift
    "${runtime}" run --rm \
        --network=none \
        --cap-drop=ALL \
        --read-only \
        --security-opt=no-new-privileges=true \
        --pids-limit=128 \
        --tmpfs=/tmp:rw,nosuid,nodev,noexec,size=16m \
        "${image}" "$@"
}

command_name="${1:-help}"
if (( $# > 0 )); then
    shift
fi

case "${command_name}" in
    help|--help|-h)
        if (( $# != 0 )); then
            printf 'help accepts no arguments.\n' >&2
            exit 2
        fi
        usage
        ;;
    build)
        if (( $# != 0 )); then
            printf 'build accepts no arguments.\n' >&2
            exit 2
        fi
        runtime="$(runtime_path)"
        "${runtime}" image inspect "${core_image}" >/dev/null 2>&1 || {
            printf 'Core image is not installed: %s\n' "${core_image}" >&2
            printf 'Run: make build\n' >&2
            exit 1
        }
        source_commit="$(
            git -C "${project_dir}" rev-parse --verify HEAD 2>/dev/null \
                || printf 'unknown\n'
        )"
        source_digest="$(
            cd "${project_dir}"
            sha256sum \
                Containerfile.webrtc \
                webrtc-peer/go.mod \
                webrtc-peer/go.sum \
                webrtc-peer/main.go \
                webrtc-peer/relay.go \
                webrtc-peer/signaling.go \
                | sha256sum | cut -d ' ' -f 1
        )"
        "${runtime}" build \
            --build-arg "BASE_IMAGE=${core_image}" \
            --build-arg "SIPPYCUP_WEBRTC_COMMIT=${source_commit}" \
            --build-arg "SIPPYCUP_WEBRTC_SOURCE_DIGEST=${source_digest}" \
            --tag "${image}" \
            --file "${project_dir}/Containerfile.webrtc" \
            "${project_dir}"
        ;;
    status)
        if (( $# != 0 )); then
            printf 'status accepts no arguments.\n' >&2
            exit 2
        fi
        runtime="$(runtime_path)"
        if image_exists "${runtime}"; then
            printf 'WebRTC profile: installed\n'
            printf 'Image: %s\n' "${image}"
            printf 'Network activity: none\n'
        else
            printf 'WebRTC profile: not installed\n'
            printf 'Install: ./bin/sippycup webrtc build\n'
            printf 'Network activity: none\n'
            exit 1
        fi
        ;;
    capabilities)
        if (( $# != 0 )); then
            printf 'capabilities accepts no arguments.\n' >&2
            exit 2
        fi
        runtime="$(runtime_path)"
        require_image "${runtime}"
        run_confined "${runtime}" capabilities
        ;;
    validate)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-validate" "$@"
        ;;
    self-test)
        runtime="$(runtime_path)"
        require_image "${runtime}"
        run_confined "${runtime}" self-test "$@"
        ;;
    signaling-self-test)
        runtime="$(runtime_path)"
        require_image "${runtime}"
        run_confined "${runtime}" signaling-self-test "$@"
        ;;
    relay-self-test)
        runtime="$(runtime_path)"
        require_image "${runtime}"
        run_confined "${runtime}" relay-self-test "$@"
        ;;
    exit-gate)
        if (( $# != 0 )); then
            printf 'exit-gate accepts no arguments.\n' >&2
            exit 2
        fi
        runtime="$(runtime_path)"
        require_image "${runtime}"
        gate_root="$(mktemp -d "${TMPDIR:-/tmp}/sippycup-webrtc-gate.XXXXXX")"
        readonly gate_root
        trap 'rm -rf -- "${gate_root}"' EXIT
        run_confined "${runtime}" self-test >"${gate_root}/direct.json"
        run_confined "${runtime}" relay-self-test >"${gate_root}/relay.json"
        run_confined "${runtime}" signaling-self-test >"${gate_root}/signaling.json"
        set +e
        run_confined "${runtime}" signaling-self-test \
            --seed-failure origin-accept \
            >"${gate_root}/seeded.json" 2>"${gate_root}/seeded.stderr"
        seeded_status=$?
        run_confined "${runtime}" self-test --timeout 1s \
            >"${gate_root}/cancelled.json" 2>"${gate_root}/cancelled.stderr"
        cancellation_status=$?
        set -e
        if (( seeded_status == 0 )); then
            printf 'Seeded WSS failure unexpectedly passed.\n' >&2
            exit 1
        fi
        if (( cancellation_status == 0 )); then
            printf 'One-second cancellation control unexpectedly passed.\n' >&2
            exit 1
        fi
        run_confined "${runtime}" signaling-self-test >"${gate_root}/recovery.json"
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-exit-gate" \
            --direct "${gate_root}/direct.json" \
            --relay "${gate_root}/relay.json" \
            --signaling "${gate_root}/signaling.json" \
            --seeded "${gate_root}/seeded.json" \
            --recovery "${gate_root}/recovery.json" \
            --cancellation-observed
        ;;
    ice-turn)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-ice-turn" "$@"
        ;;
    sdp)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-sdp" "$@"
        ;;
    media-security)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-media-security" "$@"
        ;;
    call-evidence)
        PYTHONPATH="${project_dir}/lib${PYTHONPATH:+:${PYTHONPATH}}" \
            "${project_dir}/bin/webrtc-call-evidence" "$@"
        ;;
    *)
        printf 'Unknown WebRTC profile command: %s\n' "${command_name}" >&2
        usage >&2
        exit 2
        ;;
esac

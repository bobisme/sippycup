#!/usr/bin/env python3
"""Immutable envelope planning and deterministic ramp simulation."""

from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))

from sippycup.envelope import main


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("sippycup envelope: interrupted", file=sys.stderr)
        raise SystemExit(130)

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/commands-v1.schema.json",
  "title": "Sippycup public command registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "commands", "networkActivity"],
  "properties": {
    "apiVersion": {
      "const": "sippycup.dev/commands/v1"
    },
    "networkActivity": {
      "const": false
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "group", "activity", "execution", "summary"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "group": {
            "type": "string",
            "minLength": 1
          },
          "activity": {
            "enum": [
              "offline",
              "local-network",
              "local-network-admin",
              "network",
              "network-admin"
            ]
          },
          "execution": {
            "enum": [
              "builtin",
              "doctor",
              "workbench",
              "direct",
              "host",
              "container",
              "container-isolated",
              "container-offline"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

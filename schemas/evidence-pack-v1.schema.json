{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/evidence-pack-v1.schema.json",
  "title": "Sippycup portable evidence pack manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "contentIdentity",
    "artifacts",
    "supplyChain"
  ],
  "properties": {
    "apiVersion": {"const": "sippycup.dev/evidence-pack/v1"},
    "kind": {"const": "PortableEvidencePack"},
    "contentIdentity": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifacts": {
      "type": "array",
      "maxItems": 9998,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "mediaType",
          "size",
          "sha256",
          "provenance",
          "sensitivity"
        ],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "mediaType": {"type": "string", "minLength": 1},
          "size": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "provenance": {"type": "string", "minLength": 1},
          "sensitivity": {
            "enum": ["public", "internal", "confidential", "restricted"]
          }
        }
      }
    },
    "supplyChain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imageDigest", "sbom"],
      "properties": {
        "imageDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "sbom": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "spdxVersion", "name", "packages"],
          "properties": {
            "format": {"const": "SPDX"},
            "spdxVersion": {"const": "SPDX-2.3"},
            "name": {"const": "sippycup-evidence-pack"},
            "packages": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "versionInfo", "downloadLocation"],
                "properties": {
                  "name": {"type": "string", "minLength": 1},
                  "versionInfo": {"type": "string", "minLength": 1},
                  "downloadLocation": {"type": "string", "minLength": 1}
                }
              }
            }
          }
        }
      }
    }
  }
}

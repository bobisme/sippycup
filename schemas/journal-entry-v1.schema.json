{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/journal-entry-v1.schema.json",
  "title": "Sippycup assessment journal entry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "sequence",
    "recordedAt",
    "kind",
    "summary",
    "detail",
    "evidence",
    "tags",
    "previousSha256",
    "entrySha256"
  ],
  "properties": {
    "apiVersion": {"const": "sippycup.dev/journal-entry/v1"},
    "sequence": {"type": "integer", "minimum": 1},
    "recordedAt": {"type": "string", "minLength": 1, "maxLength": 64},
    "kind": {
      "enum": [
        "authorization",
        "hypothesis",
        "action",
        "observation",
        "finding",
        "decision",
        "follow-up",
        "note"
      ]
    },
    "summary": {"type": "string", "minLength": 1, "maxLength": 500},
    "detail": {"type": "string", "maxLength": 65536},
    "evidence": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "tags": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]{0,62}$"
      }
    },
    "previousSha256": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      ]
    },
    "entrySha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

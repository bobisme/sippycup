{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/mcp-live-trust-v1.schema.json",
  "title": "Sippycup live MCP public-key trust manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "keys"],
  "properties": {
    "apiVersion": {"const": "sippycup.dev/mcp-live-trust/v1"},
    "keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "issuer", "publicKey"],
        "properties": {
          "keyId": {"type": "string", "minLength": 1, "maxLength": 128},
          "issuer": {"type": "string", "minLength": 1, "maxLength": 128},
          "publicKey": {"type": "string", "minLength": 1, "maxLength": 512}
        }
      }
    }
  }
}

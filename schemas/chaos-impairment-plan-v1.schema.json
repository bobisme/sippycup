{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/chaos-impairment-plan-v1.schema.json",
  "title": "Sippycup deterministic impairment command plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "noChange", "profile", "topology", "owner", "directions", "commands", "execution"],
  "properties": {
    "apiVersion": {"const": "sippycup.dev/chaos-impairment-plan/v1"},
    "kind": {"const": "ChaosImpairmentPlan"},
    "noChange": {"const": true},
    "profile": {"type": "object"},
    "topology": {"type": "object"},
    "owner": {"type": "string", "pattern": "^sippycup-[0-9a-f]{8}-[0-9a-f]{8}$"},
    "directions": {"type": "array", "minItems": 1},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "direction", "namespace", "argv", "owns"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "direction": {"enum": ["egress", "ingress"]},
          "namespace": {"type": "string", "minLength": 1},
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "owns": {"type": "string", "minLength": 1}
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed", "requiresLifecycleApply", "expiresAfterSeconds"],
      "properties": {
        "performed": {"const": false},
        "requiresLifecycleApply": {"const": true},
        "expiresAfterSeconds": {"type": "integer", "minimum": 1, "maximum": 3600}
      }
    }
  }
}

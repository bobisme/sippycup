{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.invalid/schemas/media-session-v1.schema.json",
  "title": "Sippycup negotiated media send session",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "direction",
    "codec",
    "digits",
    "echo",
    "revisions"
  ],
  "properties": {
    "apiVersion": {
      "const": "sippycup.media-session/v1"
    },
    "direction": {
      "enum": [
        "caller_to_callee",
        "callee_to_caller"
      ]
    },
    "codec": {
      "enum": [
        "PCMU",
        "PCMA",
        "G722"
      ]
    },
    "digits": {
      "type": "string",
      "maxLength": 16,
      "pattern": "^[0-9*#A-D]*$"
    },
    "echo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "timeoutMs"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 20,
          "maximum": 5000
        }
      }
    },
    "revisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "activationMs",
          "localSdp",
          "remoteSdp"
        ],
        "properties": {
          "activationMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 980,
            "multipleOf": 20
          },
          "localSdp": {
            "type": "string",
            "maxLength": 32768
          },
          "remoteSdp": {
            "type": "string",
            "maxLength": 32768
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.dev/schemas/mcp-result-v1.schema.json",
  "title": "Sippycup MCP tool result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "tool",
    "ok",
    "networkActivity",
    "sensitivity",
    "durationMs",
    "data",
    "warnings",
    "errors",
    "artifacts",
    "truncated"
  ],
  "properties": {
    "apiVersion": {
      "const": "sippycup.dev/mcp-result/v1"
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "networkActivity": {
      "const": false
    },
    "sensitivity": {
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "data": true,
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "truncated": {
      "type": "boolean"
    }
  }
}

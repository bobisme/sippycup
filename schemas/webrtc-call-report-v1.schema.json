{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sippycup.invalid/schemas/webrtc-call-report-v1.schema.json",
  "title": "Sippycup WebRTC cross-layer call report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "status",
    "networkActivity",
    "observedNetworkActivity",
    "callIdHash",
    "generations",
    "ssrcs",
    "findings",
    "unknowns",
    "privacy",
    "capacityClaim"
  ],
  "properties": {
    "apiVersion": {"const": "sippycup.dev/webrtc-call-report/v1"},
    "status": {"enum": ["pass", "fail", "incomplete"]},
    "networkActivity": {"const": false},
    "observedNetworkActivity": {"type": "boolean"},
    "callIdHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "generations": {"type": "integer", "minimum": 0, "maximum": 1024},
    "ssrcs": {"type": "integer", "minimum": 0, "maximum": 4096},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "generation", "detail"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 128},
          "generation": {"type": "integer", "minimum": -1, "maximum": 65535},
          "detail": {"type": "string", "maxLength": 256}
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 128},
          "component": {"type": "string", "maxLength": 128},
          "generation": {"type": "integer", "minimum": 0, "maximum": 65535},
          "layer": {"type": "string", "maxLength": 128},
          "direction": {"enum": ["outbound", "inbound"]}
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateAddressesRetained",
        "credentialsRetained",
        "browserMetadataRetained",
        "rawAudioRetained"
      ],
      "properties": {
        "candidateAddressesRetained": {"const": false},
        "credentialsRetained": {"const": false},
        "browserMetadataRetained": {"const": false},
        "rawAudioRetained": {"const": false}
      }
    },
    "capacityClaim": {"type": "null"}
  }
}

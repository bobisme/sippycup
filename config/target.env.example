# Copy this file to config/target.env after your friend supplies the staging
# details. Do not store a SIP password or production credential here.

FERIVOX_TARGET_HOST=staging.example.invalid
FERIVOX_SIP_PORT=5060
FERIVOX_SIP_TRANSPORT=udp

# Ask whether signaling and media use the same address. These are notes for
# constructing ./bin/capture arguments, not values consumed automatically.
FERIVOX_SIGNALING_SCOPE=staging.example.invalid
FERIVOX_MEDIA_SCOPE=staging.example.invalid

FERIVOX_TEST_EXTENSION=
FERIVOX_EXPECTED_MEDIA=RTP
FERIVOX_EXPECTED_CODECS=PCMU,PCMA

# Obtain explicit limits before load or resilience testing.
FERIVOX_MAX_CALL_RATE=1
FERIVOX_MAX_CONCURRENT_CALLS=1
FERIVOX_MAX_PACKET_RATE=
